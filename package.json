{
  "name": "riskrask",
  "private": true,
  "version": "0.1.0",
  "description": "Risk — Cold War Edition. TypeScript monorepo.",
  "workspaces": ["apps/*", "packages/*", "scripts"],
  "scripts": {
    "dev": "echo 'run bun --filter <name> dev (web|server|admin)'",
    "dev:web": "bun --filter @riskrask/web dev",
    "dev:server": "bun --filter @riskrask/server dev",
    "dev:admin": "bun --filter @riskrask/admin dev",
    "build": "bun --filter='*' run build",
    "test": "bun --filter='*' run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "bun --filter='*' run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.12",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
