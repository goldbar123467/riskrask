# Root template. Each app has its own .env.example with the keys it needs.
# - apps/server/.env.example
# - apps/web/.env.example
# - apps/admin/.env.example
#
# Local dev convenience: copy each one to .env (or .env.local) in the same dir.
# Production: secrets live in ~/.config/riskrask/.env.prod on the Hetzner box.
