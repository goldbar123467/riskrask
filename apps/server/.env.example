# --- runtime ---
PORT=8787
NODE_ENV=production

# CORS — comma-separated origin allowlist
ALLOWED_ORIGINS=https://www.riskrask.com,https://admin.riskrask.com

# --- supabase ---
# Public URL of the Supabase project (e.g. https://abcd.supabase.co)
SUPABASE_URL=
# Anon key — safe to use server-side; not exposed to web
SUPABASE_ANON_KEY=
# Service-role key — full-access; NEVER expose to web. Accepts both new
# `sb_secret_…` keys and legacy JWT service-role keys.
SUPABASE_SERVICE_ROLE_KEY=
# JWT audience expected on Supabase Auth tokens (default: "authenticated")
SUPABASE_JWT_AUD=authenticated

# --- cloudflare access (admin gating) ---
# https://<team>.cloudflareaccess.com — found in Zero Trust dashboard
CF_ACCESS_TEAM_DOMAIN=
# Application Audience tag — found in the Access app you created
CF_ACCESS_AUD=

# --- turnstile (signup + room create) ---
TURNSTILE_SECRET=

# --- observability ---
GIT_SHA=
