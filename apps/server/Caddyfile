{
	# email kept for ACME notifications (unused when we use a static cert)
	email kitchen@imsaindy.org
	# Disable automatic HTTPS issuance — we use the CF Origin cert
	auto_https disable_redirects
}

api.upsidedownatlas.com {
	tls /certs/origin.crt /certs/origin.key
	encode gzip zstd

	reverse_proxy server:8787 {
		header_up Host {host}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		header_up X-Forwarded-Proto {scheme}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format json
		level INFO
	}
}

# Catch-all so direct hits to the IP do not leak the API host
:80 {
	respond "riskrask" 200
}
